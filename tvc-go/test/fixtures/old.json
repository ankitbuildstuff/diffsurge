{
  "name": "TVC API",
  "version": "1.0.0",
  "endpoints": [
    {
      "path": "/api/v1/users",
      "method": "GET",
      "description": "List all users"
    },
    {
      "path": "/api/v1/users/:id",
      "method": "GET",
      "description": "Get user by ID"
    }
  ],
  "config": {
    "timeout": 30,
    "retries": 3,
    "cache": {
      "enabled": true,
      "ttl": 300
    }
  }
}
