# ===========================================
# Supabase (required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ===========================================
# App URLs
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8081

# ===========================================
# Backend Storage (used by docker-compose)
# ===========================================
TVC_STORAGE_POSTGRES_URL=postgres://tvc:tvc_dev_pass@localhost:5432/tvc_dev?sslmode=disable
TVC_STORAGE_REDIS_URL=redis://localhost:6379

# ===========================================
# OAuth Providers (optional — configure in Supabase dashboard)
# ===========================================
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
